root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# Java & Gradle Kotlin DSL — 4-space indent
[*.{java,gradle.kts}]
indent_style = space
indent_size = 4

# Dart — 2-space indent
[*.dart]
indent_style = space
indent_size = 2

# Markup / config — 2-space indent
[*.{md,yaml,yml,json}]
indent_style = space
indent_size = 2

# Markdown keeps trailing whitespace (two spaces = hard line break)
[*.md]
trim_trailing_whitespace = false
